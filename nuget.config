<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- CommunityToolkit Labs & MainLatest - public Azure feeds, no auth needed -->
    <add key="labs.windows" value="https://pkgs.dev.azure.com/dotnet/CommunityToolkit/_packaging/CommunityToolkit-Labs/nuget/v3/index.json" />
    <add key="community" value="https://pkgs.dev.azure.com/dotnet/CommunityToolkit/_packaging/CommunityToolkit-MainLatest/nuget/v3/index.json" />
    <!-- .NET 9 preview/RC packages from dotnet9 public feed -->
    <add key="dotnet9" value="https://pkgs.dev.azure.com/dnceng/public/_packaging/dotnet9/nuget/v3/index.json" />
    <!-- REMOVED: 'sergio' private source (Sergio0694/ComputeSharp) - all packages now on nuget.org -->
  </packageSources>
    <disabledPackageSources>
        <clear />
        <add key="sergio" value="true" />
    </disabledPackageSources>
</configuration>
